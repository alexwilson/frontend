{
  "name": "@alexwilson/auth",
  "version": "2.0.0",
  "description": "Auth Worker",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply auth-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply auth-db --remote",
    "db:migrate:list": "wrangler d1 migrations list auth-db --remote",
    "db:migrate:create": "wrangler d1 migrations create auth-db"
  },
  "author": "Alex Wilson <alex@alexwilson.tech>",
  "type": "module",
  "license": "ISC",
  "dependencies": {
    "@octokit/request": "10.0.9",
    "better-auth": "1.6.11",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.27"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@cloudflare/workers-types": "4.20260515.1",
    "@picocss/pico": "2.1.1",
    "@types/better-sqlite3": "7.6.13",
    "better-sqlite3": "12.10.0",
    "drizzle-kit": "0.31.10",
    "typescript": "7.0.2",
    "vitest": "4.1.8",
    "wrangler": "4.93.0"
  }
}
