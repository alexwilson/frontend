    "@octokit/core": "7.0.6",
    "gatsby": "5.16.1",
    "gatsby-plugin-sass": "6.16.0",
    "gatsby-source-github-repository": "workspace:*",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-virtuoso": "4.18.7",
    "sass": "1.99.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260515.1",
    "@types/node": "25.8.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
