{
  "name": "@alexwilson/reader",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "gatsby build --prefix-paths",
    "clean": "gatsby clean",
    "develop": "gatsby develop",
    "start": "npm run develop",
    "serve": "gatsby serve --prefix-paths",
    "dev:worker": "wrangler dev",
