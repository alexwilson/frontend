{
  "name": "@alexwilson/reader",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel dev:client dev:worker",
    "dev:client": "vite client",
    "dev:worker": "wrangler dev",
    "build": "vite build client",
    "preview": "vite preview client",
    "deploy:client": "aws s3 sync --acl=public-read --delete ./dist/ s3://alex-static-assets/reader/",
    "deploy:worker": "wrangler deploy",
    "deploy": "npm run build && npm run deploy:client && npm run deploy:worker",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json"
  },
  "author": "Alex Wilson <alex@alexwilson.tech>",
  "license": "ISC",
  "dependencies": {
    "@alexwilson/ds-legacy-components": "workspace:*",
    "@octokit/auth-app": "8.2.0",
    "@octokit/core": "7.0.6",
    "jose": "6.2.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "7.18.0",
    "react-virtuoso": "4.18.7",
    "sass": "1.99.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260515.1",
    "@types/node": "25.8.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.2",
    "npm-run-all": "4.1.5",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.8",
    "wrangler": "4.93.0"
  }
}
