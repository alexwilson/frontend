{
  "name": "@alexwilson/cms",
  "version": "1.0.0",
  "description": "Netlify-CMS distribution",
  "scripts": {
    "build:client": "webpack --config webpack.client.cjs",
    "build:worker": "webpack --config webpack.worker.cjs",
    "build": "npm-run-all build:*",
    "deploy:client": "aws s3 sync --acl=public-read --delete ./dist/ s3://alex-static-assets/cms/",
    "deploy:worker": "wrangler deploy",
    "deploy": "npm-run-all build:* deploy:*",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "develop": "webpack serve --config webpack.client.cjs",
    "start": "NODE_ENV=production PROFILE=true webpack serve --config webpack.client.cjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json"
  },
  "author": "Alex Wilson <alex@alexwilson.tech>",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "ajv": "8.20.0",
    "ajv-errors": "3.0.0",
    "ajv-keywords": "5.1.0",
    "babel-loader": "10.1.1",
    "css-loader": "7.1.4",
    "html-webpack-plugin": "5.6.7",
    "js-yaml": "4.1.1",
    "jsdom": "29.1.1",
    "npm-run-all": "4.1.5",
    "path-browserify": "1.0.1",
    "raw-loader": "4.0.2",
    "sass": "1.99.0",
    "sass-loader": "16.0.8",
    "stream-browserify": "3.0.0",
    "style-loader": "4.0.0",
    "terser-webpack-plugin": "5.6.0",
    "typescript": "7.0.2",
    "url": "0.11.4",
    "vitest": "4.1.8",
    "webpack": "5.106.2",
    "webpack-bundle-analyzer": "5.3.0",
    "webpack-cli": "7.0.2",
    "webpack-dev-server": "5.2.4",
    "wrangler": "4.93.0"
  },
  "dependencies": {
    "@alexwilson/content": "workspace:*",
    "@alexwilson/ds-columns": "workspace:*",
    "@alexwilson/ds-legacy-components": "workspace:*",
    "better-auth": "1.6.13",
    "date-fns": "4.4.0",
    "decap-cms": "3.14.0",
    "decap-cms-app": "3.14.0",
    "decap-cms-backend-github": "3.7.0",
    "decap-cms-backend-proxy": "3.4.0",
    "decap-cms-ui-default": "3.8.0",
    "jose": "6.2.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rehype-stringify": "10.0.1",
    "remark-directive": "3.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "remark-stringify": "11.0.0",
    "unified": "11.0.5",
    "uuid": "14.0.0"
  }
}
