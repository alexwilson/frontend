---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import SEO from '../components/SEO.astro';
import Layout from '../components/Layout.astro';
import ArticleCard from '@alexwilson/legacy-components/src/article-card';
import Header from '@alexwilson/legacy-components/src/header';
import { resolveContent } from '../lib/content';
import { resolveTopics } from '../lib/topics';

const siteUrl = 'https://alexwilson.tech';
const url = new URL('/blog', siteUrl);

const allPosts = await getCollection('posts');

function resolve(entry: (typeof allPosts)[0]) {
  const topics = resolveTopics(entry.data.tags);
  return resolveContent(entry, topics);
}

const content = allPosts
  .map(resolve)
  .filter(
    (c) =>
      (c.type === 'article' || c.type === 'content-placeholder') &&
      !c.topics.some((t) => t.topic === 'lists'),
  )
  .sort((a, b) => b.date.getTime() - a.date.getTime());
---

<Base>
  <SEO title="Blog" slot="head" />
  <Layout pathname={Astro.url.pathname} section="blog">
    <div class="alex-stream">
      <h1>My Blog</h1>
      <h4>{content.length} Posts</h4>
      {content.map((node) => (
        <ArticleCard client:load article={node} />
      ))}
    </div>
  </Layout>
</Base>
